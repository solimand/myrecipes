---
import { sanityClient } from "sanity:client";
import { urlFor } from "../utils/urlFor";

const allRecipes = await sanityClient.fetch(`*[_type == "recipe"]{
  title,
  category,
  mainImage, 
  "slug": slug.current
} | order(title asc)`);

const recipesByCategory = allRecipes.reduce((acc, recipe) => {
  const cat = recipe.category || "Uncategorized";
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(recipe);
  return acc;
}, {});

const categories = Object.keys(recipesByCategory).sort();
// Define base once for cleaner HTML
const base = import.meta.env.BASE_URL;
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>My Recipe Dashboard</title>
    <style>
        /* Base styles */
        body { font-family: system-ui, sans-serif; padding: 1rem; background: #f4f7f6; color: #333; margin: 0; }
        
        /* 1. Mobile First: Single Column */
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr; 
            gap: 1.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* 2. Desktop: Two Columns (for screens wider than 768px) */
        @media (min-width: 768px) {
            body { padding: 2rem; }
            .dashboard-grid {
                grid-template-columns: 1fr 1fr;
                gap: 2rem;
            }
        }

        .column {
            background: white;
            padding: 1.5rem;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            height: fit-content; /* Adjusts to content height on mobile */
        }

        @media (min-width: 768px) {
            .column { min-height: 80vh; }
        }

        h1 { text-align: center; margin-bottom: 2rem; color: #1a1a1a; }
        h2 { border-bottom: 2px solid #eee; padding-bottom: 0.5rem; margin-top: 0; font-size: 1.2rem; }
        
        .category-block { margin-bottom: 1.5rem; }
        .category-name { 
            font-weight: bold; 
            text-transform: uppercase; 
            font-size: 0.75rem; 
            color: #ff4757; 
            letter-spacing: 1px;
        }

        ul { list-style: none; padding: 0; }
        li { margin: 0.8rem 0; }
        
        .recipe-link-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: #2f3542;
            transition: transform 0.2s;
        }
        .recipe-link-wrapper:hover { transform: translateX(5px); }
        .recipe-link-wrapper:hover span { color: #ff4757; text-decoration: underline; }

        .thumb {
            width: 40px;
            height: 40px;
            border-radius: 6px;
            object-fit: cover;
            background: #eee;
            flex-shrink: 0; /* Prevents image from squishing on small screens */
        }

        .recipe-tag { 
            font-size: 0.7rem; 
            background: #e1e1e1; 
            padding: 2px 6px; 
            border-radius: 4px; 
            margin-left: auto; 
            color: #666;
            white-space: nowrap;
        }
    </style>
</head>
<body>

    <h1>My Gourmet Corner</h1>

    <div class="dashboard-grid">
        
        <section class="column">
            <h2>Categories</h2>
            {categories.map(cat => (
                <div class="category-block">
                    <span class="category-name">{cat}</span>
                    <ul>
                        {recipesByCategory[cat].map(recipe => (
                            <li>
                                <a href={`${base}/recipe/${recipe.slug}`} class="recipe-link-wrapper">
                                    {recipe.mainImage && (
                                        <img src={urlFor(recipe.mainImage).width(80).height(80).url()} class="thumb" alt="" />
                                    )}
                                    <span>{recipe.title}</span>
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </section>

        <section class="column">
            <h2>All Recipes ({allRecipes.length})</h2>
            <ul>
                {allRecipes.map(recipe => (
                    <li>
                        <a href={`${base}/recipe/${recipe.slug}`} class="recipe-link-wrapper">
                            {recipe.mainImage && (
                                <img src={urlFor(recipe.mainImage).width(80).height(80).url()} class="thumb" alt="" />
                            )}
                            <span>{recipe.title}</span>
                            <span class="recipe-tag">{recipe.category}</span>
                        </a>
                    </li>
                ))}
            </ul>
        </section>

    </div>

</body>
</html>
